{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobserver.example.io/schemas/rest/jobs-list-response.schema.json",
  "title": "Jobs List Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "items",
    "next_cursor"
  ],
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 200,
      "items": {
        "$ref": "../models/job.schema.json"
      }
    },
    "next_cursor": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        {
          "type": "null"
        }
      ]
    }
  }
}
