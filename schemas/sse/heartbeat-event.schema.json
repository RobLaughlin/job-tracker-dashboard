{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobserver.example.io/schemas/sse/heartbeat-event.schema.json",
  "title": "SSE Heartbeat Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "job_id",
    "payload"
  ],
  "properties": {
    "event_id": {
      "$ref": "../models/common.schema.json#/$defs/eventId"
    },
    "event_type": {
      "type": "string",
      "const": "heartbeat"
    },
    "schema_version": {
      "$ref": "../models/common.schema.json#/$defs/schemaVersion"
    },
    "occurred_at": {
      "$ref": "../models/common.schema.json#/$defs/timestamp"
    },
    "job_id": {
      "$ref": "../models/common.schema.json#/$defs/jobId"
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "interval_seconds"
      ],
      "properties": {
        "interval_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 300
        }
      }
    }
  }
}
