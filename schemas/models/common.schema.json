{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jobserver.example.io/schemas/models/common.schema.json",
  "title": "Common Types",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "const": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "jobId": {
      "$ref": "#/$defs/identifier"
    },
    "taskId": {
      "$ref": "#/$defs/identifier"
    },
    "dependencyId": {
      "$ref": "#/$defs/identifier"
    },
    "jobStatus": {
      "type": "string",
      "enum": [
        "queued",
        "waiting_dependency",
        "running",
        "failed",
        "completed",
        "succeeded",
        "cancelled"
      ]
    },
    "taskStatus": {
      "type": "string",
      "enum": ["queued", "running", "succeeded", "failed", "cancelled"]
    },
    "eventId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_-]+$"
    }
  }
}
