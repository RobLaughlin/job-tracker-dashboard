{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate && tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.mjs\" \"*.{json,md,js}\" \"../*.{md,yaml,yml}\" \"../docs/**/*.md\" \"../openapi.yaml\" \"../schemas/**/*.json\" \"../examples/**/*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"scripts/**/*.mjs\" \"*.{json,md,js}\" \"../*.{md,yaml,yml}\" \"../docs/**/*.md\" \"../openapi.yaml\" \"../schemas/**/*.json\" \"../examples/**/*.{js,json,md}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "generate:types": "node scripts/generate-types.mjs",
    "generate:validators": "node scripts/generate-validators.mjs",
    "generate": "npm run generate:types && npm run generate:validators",
    "check:generated": "node scripts/generate-types.mjs --check && node scripts/generate-validators.mjs --check",
    "verify:precommit": "npm run check:generated && npm run typecheck && npm run lint && npm run format:check",
    "verify:prepush": "npm run verify:precommit && npm run test"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "^6.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.6.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
